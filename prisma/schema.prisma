generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id        Int       @id @default(autoincrement()) @db.UnsignedInt
  name      String    @db.VarChar(63)
  email     String    @db.VarChar(127)
  password  String    @db.VarChar(127)
  birthAt   DateTime? @db.Date
  createdAt DateTime  @default(now()) @db.Timestamp(0)
  updatedAt DateTime  @default(now()) @db.Timestamp(0)
  role      Int       @default(1)
  height    Int?
  weight    Float?
  cpf       String    @db.Char(11)
  responsibilities UserResponsibility[] @relation("UserResponsible")
  dependents UserResponsibility[] @relation("UserDependent")

  @@map("users")
}

model measurement {
  measurement_ID Int     @id @default(autoincrement())
  equipment_ID   Int?
  user_ID        Int
  value          Float  @db.Float
  unit           String? @db.VarChar(50)
  createdAt DateTime  @default(now()) @db.Timestamp(0)
}

model UserResponsibility {
  id                 Int  @id @default(autoincrement())
  responsibleUserId  Int @db.UnsignedInt
  dependentUserId    Int @db.UnsignedInt
  responsibleUser    User @relation("UserResponsible", fields: [responsibleUserId], references: [id])
  dependentUser      User @relation("UserDependent", fields: [dependentUserId], references: [id])

  @@map("user_responsibilities")
  @@unique([responsibleUserId, dependentUserId])
}
